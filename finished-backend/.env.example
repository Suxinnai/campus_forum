# Campus Forum Backend - Environment Variables Template
# Copy this file to .env and fill in your values.
# Spring Boot will read these from system environment or .env via a plugin.

# ---- Database ----
DB_URL=jdbc:mysql://localhost:3306/campus_forum?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password

# ---- JWT ----
JWT_KEY=your-secure-jwt-secret-key

# ---- Mail (SMTP) ----
MAIL_HOST=smtp.163.com
MAIL_USERNAME=your_email@163.com
MAIL_PASSWORD=your_smtp_auth_code

# ---- RabbitMQ ----
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ---- MinIO (Object Storage) ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_USERNAME=minioadmin
MINIO_PASSWORD=minioadmin

# ---- Weather API ----
WEATHER_KEY=your_weather_api_key
